# ============================================================
#  APILayer — Server-Side Configuration
#  Apply at: apilayer.com/marketplace/submit
#  Commission: 15% (you keep 85%) — best rate of any marketplace
#  Model: proxy — APILayer proxies requests to your server
# ============================================================

# ── Your Server ───────────────────────────────────────────────
# In the APILayer submission form, set your base URL to:
#   https://YOUR_DOMAIN/v1
DOMAIN=your-server-domain.com
SSL_EMAIL=your@email.com

# ── APILayer Injected Headers (handled by gateway automatically) ─
# APILayer sends these headers with every forwarded request:
#   apikey: <subscriber's key>
#   X-User-Key: <subscriber's key> (some endpoints)
#
# The gateway already handles `apikey` header authentication.
# No extra config needed.

# ── Security ──────────────────────────────────────────────────
ADMIN_SECRET=replace_with_a_strong_random_secret
ALLOW_ANONYMOUS=false

# ── Tier API Keys ─────────────────────────────────────────────
# You can pre-register test API keys for APILayer review process.
# Format: KEY:tier (comma separated, no spaces around colon)
# These go into the gateway's key store.
API_KEYS=apilayer-test-key-basic:basic,apilayer-test-key-pro:pro

# ── Upstream API Keys ─────────────────────────────────────────
NASA_API_KEY=your_nasa_api_key
TED_API_KEY=your_ted_api_key

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
DASHBOARD_PASSWORD=replace_with_strong_password

# ============================================================
#  WHAT TO SUBMIT TO APILAYER
#
#  APILayer is curated — they review before listing.
#  Apply at: apilayer.com/marketplace/submit
#
#  BEST APIs to submit (low/no competing products at APILayer):
#    ✅ ClinicalTrials API     → clinicaltrials.gov data
#    ✅ GBIF Biodiversity API  → species/occurrence data
#    ✅ PubChem Chemistry API  → molecular/compound data
#    ✅ World Bank Data API    → economic indicators
#    ✅ NASA Data API          → APOD, DONKI, NEO
#    ✅ Air Quality API        → OpenAQ open data
#    ✅ Name Prediction API    → age/gender/nationality
#
#  DO NOT SUBMIT (APILayer owns these categories):
#    ❌ VAT Validation        → they own Vatlayer.com
#    ❌ FX/Exchange Rates     → they own Fixer.io + Currencylayer
#
#  PRICING GUIDANCE (set in APILayer dashboard):
#  ┌──────────────┬──────────┬────────────────────────────────┐
#  │ Plan         │ Price    │ Requests/month                  │
#  ├──────────────┼──────────┼────────────────────────────────┤
#  │ Free         │ $0       │ 250 req/month                   │
#  │ Basic        │ $14/mo   │ 50,000 req/month                │
#  │ Pro          │ $49/mo   │ 500,000 req/month               │
#  └──────────────┴──────────┴────────────────────────────────┘
#
#  APILayer takes 15% commission. You keep 85%.
#  $49 Pro plan → you earn $41.65/subscriber/month
# ============================================================
