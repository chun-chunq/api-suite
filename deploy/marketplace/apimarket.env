# ============================================================
#  API.market — Server-Side Configuration
#  Register at: api.market/seller
#  Commission: 20% (negotiable to 15% above $2,500 MRR)
#  Model: proxy — API.market forwards requests to your server
#  Competition: VERY LOW across all your categories
# ============================================================

# ── Your Server ───────────────────────────────────────────────
DOMAIN=your-server-domain.com
SSL_EMAIL=your@email.com

# ── API.market Header (handled by gateway automatically) ──────
# API.market injects:
#   X-Api-Key: <subscriber's key>
#
# The gateway already supports X-Api-Key / X-API-Key headers.
# No extra config needed.

# ── Security ──────────────────────────────────────────────────
ADMIN_SECRET=replace_with_a_strong_random_secret
ALLOW_ANONYMOUS=false

# ── API Keys ──────────────────────────────────────────────────
# Pre-register test keys for API.market's review/testing:
API_KEYS=apimarket-test-basic:basic,apimarket-test-pro:pro

# ── Upstream Keys ─────────────────────────────────────────────
NASA_API_KEY=your_nasa_api_key
TED_API_KEY=your_ted_api_key

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
DASHBOARD_PASSWORD=replace_with_strong_password

# ============================================================
#  WHY API.MARKET IS WORTH IT
#
#  - ~10,000 developers (small but growing fast)
#  - Open submission — no review wait time
#  - FIRST to list in your niche = top search ranking
#  - Early mover advantage is large on this platform
#
#  LIST ALL YOUR APIS HERE. Competition is near-zero.
#
#  PRICING GUIDANCE:
#  Price slightly LOWER than RapidAPI to attract early users.
#  ┌──────────────┬──────────┬────────────────────────────────┐
#  │ Plan         │ Price    │ Requests/month                  │
#  ├──────────────┼──────────┼────────────────────────────────┤
#  │ Free         │ $0       │ 100 req/month                   │
#  │ Basic        │ $7/mo    │ 10,000 req/month                │
#  │ Pro          │ $24/mo   │ 100,000 req/month               │
#  │ Ultra        │ $79/mo   │ 1,000,000 req/month             │
#  └──────────────┴──────────┴────────────────────────────────┘
#
#  API.market takes 20% (drops to ~15% once you hit $2,500/mo MRR).
# ============================================================
