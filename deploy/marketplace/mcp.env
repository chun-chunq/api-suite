# ============================================================
#  MCP Registries — Server-Side Configuration
#
#  MCP registries are DISCOVERY channels (no revenue share).
#  Monetization: users find you on Smithery/Glama → need your
#  API key to use the server → you sell keys directly.
#
#  Supported registries:
#    1. modelcontextprotocol.io/registry  ← official, feeds others
#    2. smithery.ai                        ← largest active directory
#    3. glama.ai/mcp                       ← 30k+ servers
#    4. pulsemcp.com                       ← aggregates from official
# ============================================================

# ── Your Public Gateway URL ───────────────────────────────────
# All MCP endpoints are exposed via the gateway at:
#   https://DOMAIN/mcp/<service-name>
# Example: https://api.yourdomain.com/mcp/handelsregister
DOMAIN=your-server-domain.com
SSL_EMAIL=your@email.com

# ── MCP Auth (how clients get API keys from you) ──────────────
# When a user finds your server on Smithery/Glama, they need a key.
# Option A: Manual — email you, you create a key, add to API_KEYS
# Option B: Stripe — users pay → webhook creates key automatically
# The gateway checks X-Api-Key / X-RapidAPI-Key / Authorization: Bearer
# Gateway returns 401 (not 403) on missing/invalid key ✅ (already correct)
ALLOW_ANONYMOUS=false

# Pre-register test keys for registry review/scanning:
API_KEYS=mcp-test-free:free,mcp-test-basic:basic

# ── Official MCP Registry (modelcontextprotocol.io) ──────────
# After running deploy/generate-mcp-servers.sh:
#   1. Install: npm install -g @modelcontextprotocol/publisher
#   2. Authenticate with your domain:
#      mcp-publisher login http --domain "DOMAIN"
#   3. Publish all servers:
#      for f in deploy/mcp-servers/*.json; do mcp-publisher publish "$f"; done
MCP_REGISTRY_DOMAIN=your-server-domain.com
MCP_REGISTRY_NAMESPACE=com.your-server-domain

# ── Smithery.ai ───────────────────────────────────────────────
# After installing Smithery CLI: npm install -g @smithery/cli
# Publish each API:
#   smithery mcp publish "https://DOMAIN/mcp/handelsregister" \
#     -n @yourorg/handelsregister-api
# Or bulk publish using: deploy/publish-smithery.sh
SMITHERY_ORG=yourorg

# ── Well-Known Files ──────────────────────────────────────────
# The gateway serves /.well-known/ files automatically.
# After deploy, verify:
#   curl https://DOMAIN/.well-known/mcp-registry-auth
# This is needed for domain verification in the official registry.

# ── Admin ─────────────────────────────────────────────────────
ADMIN_SECRET=replace_with_a_strong_random_secret
LOG_LEVEL=info
DASHBOARD_PASSWORD=replace_with_strong_password

# ── Upstream API Keys (for your own upstream services) ────────
NASA_API_KEY=your_nasa_api_key
TED_API_KEY=your_ted_api_key

# ============================================================
#  MCP MONETIZATION STRATEGY
#
#  Since registries don't pay you, the flow is:
#
#    User finds API on Smithery/Glama
#      → wants to use it in Claude/ChatGPT/Cursor
#      → needs an API key
#      → goes to your website (or RapidAPI!)
#      → buys a subscription
#      → enters key when Claude Desktop asks for it
#
#  BEST APPROACH: Cross-list on both MCP registries AND RapidAPI.
#  RapidAPI handles billing. Your MCP listing drives Claude users.
#  Both point to the same backend (your gateway).
#
#  Pricing suggestion for MCP users (via direct key sales):
#    Free:  100 req/month  — $0
#    Basic: 10k req/month  — $9/month (Stripe)
#    Pro:   100k req/month — $29/month (Stripe)
# ============================================================
