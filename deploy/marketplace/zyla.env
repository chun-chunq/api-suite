# ============================================================
#  Zyla API Hub — Server-Side Configuration
#  Register at: zylalabs.com/api-marketplace/submit
#  Commission: 20%
#  Model: proxy
#  Competition: Low, but small user base (tens of thousands devs)
# ============================================================

# ── Your Server ───────────────────────────────────────────────
DOMAIN=your-server-domain.com
SSL_EMAIL=your@email.com

# ── Zyla Header ───────────────────────────────────────────────
# Zyla injects:
#   Authorization: Bearer <subscriber_token>
# The gateway handles Authorization: Bearer as a key lookup.
# No extra config needed.

# ── Security ──────────────────────────────────────────────────
ADMIN_SECRET=replace_with_a_strong_random_secret
ALLOW_ANONYMOUS=false

# ── API Keys ──────────────────────────────────────────────────
API_KEYS=zyla-test-basic:basic,zyla-test-pro:pro

# ── Upstream Keys ─────────────────────────────────────────────
NASA_API_KEY=your_nasa_api_key
TED_API_KEY=your_ted_api_key

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
DASHBOARD_PASSWORD=replace_with_strong_password

# ============================================================
#  ZYLA NOTES
#
#  - Small but active community
#  - Low effort to list (open submission)
#  - Realistic monthly revenue: $10–$150
#  - Worth listing because overhead is low once set up
#
#  Recommended strategy: list your top 10 APIs only.
#  Not worth listing all 40+ here given small audience.
#
#  Best picks for Zyla:
#    - ClinicalTrials, GBIF, PubChem, World Bank
#    - NASA, Name Prediction, Air Quality
# ============================================================
