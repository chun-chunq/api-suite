# ============================================================
#  RapidAPI — Server-Side Configuration
#  Edit this file, then source it before starting your stack:
#    cp marketplace/rapidapi.env .env   (or merge into .env)
# ============================================================

# ── Gateway Auth ─────────────────────────────────────────────
# RapidAPI injects this into every request hitting your server.
# Get it from: rapidapi.com/provider → My APIs → API Settings → Security
# Your gateway validates it to block non-RapidAPI traffic.
RAPIDAPI_PROXY_SECRET=replace_with_your_proxy_secret_from_rapidapi_dashboard

# ── How RapidAPI Connects to You ─────────────────────────────
# In RapidAPI dashboard, set your API base URL to:
#   https://YOUR_DOMAIN/v1
# RapidAPI will forward all requests to this URL.
# Make sure DOMAIN is set:
DOMAIN=your-server-domain.com
SSL_EMAIL=your@email.com

# ── Headers RapidAPI Sends (handled automatically by gateway) ─
# X-RapidAPI-Proxy-Secret: <RAPIDAPI_PROXY_SECRET above>
# X-RapidAPI-Key:          the subscriber's API key
# X-RapidAPI-Subscription: the plan name (BASIC, PRO, ULTRA...)
# X-RapidAPI-User:         the subscriber's username
#
# The gateway reads these and maps them to internal tiers.
# No extra config needed — gateway handles it automatically.

# ── Tier Mapping ──────────────────────────────────────────────
# Map RapidAPI plan names → internal rate-limit tiers
# Format: RAPIDAPI_PLAN_<PLAN_NAME>=<internal_tier>
# Internal tiers: free=20/min, basic=100/min, pro=300/min, ultra=1000/min
RAPIDAPI_PLAN_BASIC=basic
RAPIDAPI_PLAN_PRO=pro
RAPIDAPI_PLAN_ULTRA=ultra
RAPIDAPI_PLAN_MEGA=ultra

# ── Security ──────────────────────────────────────────────────
# Admin secret for /gateway/reset and /gateway/stats
ADMIN_SECRET=replace_with_a_strong_random_secret

# Anonymous access (free tier): allow or block requests without API key
# On RapidAPI, unauthenticated requests shouldn't reach you (RapidAPI handles it)
# but set to false for safety:
ALLOW_ANONYMOUS=false

# ── Additional API Keys (for your own upstream services) ──────
NASA_API_KEY=your_nasa_api_key
TED_API_KEY=your_ted_api_key
COMPANIES_HOUSE_API_KEY=your_companies_house_key

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_PASSWORD=replace_with_strong_password

# ── Proxy Settings (optional, for outbound requests) ─────────
# If your server has a static IP and you need proxies for upstream APIs:
# PROXY_LIST=http://proxy1:port,http://proxy2:port
# PROXY_ROTATION=round-robin

# ============================================================
#  RAPIDAPI PRICING GUIDE (set in RapidAPI dashboard, not here)
#
#  Recommended pricing for your niche APIs:
#  ┌─────────────────────┬──────────┬──────────────────────────┐
#  │ Plan                │ Price    │ Requests/month            │
#  ├─────────────────────┼──────────┼──────────────────────────┤
#  │ Free                │ $0       │ 100 req/month             │
#  │ Basic               │ $9/mo    │ 10,000 req/month          │
#  │ Pro                 │ $29/mo   │ 100,000 req/month         │
#  │ Ultra               │ $99/mo   │ 1,000,000 req/month       │
#  └─────────────────────┴──────────┴──────────────────────────┘
#
#  RapidAPI takes 20% commission. You keep 80%.
#  $29 Pro plan → you earn $23.20/subscriber/month
# ============================================================
