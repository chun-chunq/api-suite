# ══════════════════════════════════════════════════════════════════════════════
#  .env.template — copy to .env and fill in your values
#  NEVER commit .env to git (it contains secrets)
# ══════════════════════════════════════════════════════════════════════════════

# ── API access keys ────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for customers.
# Add a key for each RapidAPI/APILayer plan (or your own customers).
# Generate: openssl rand -hex 20
API_KEYS=my-secret-key-1,my-secret-key-2

# ── Admin access ───────────────────────────────────────────────────────────────
# Used for /admin/* endpoints (analytics, worker management, stats).
# Generate: openssl rand -hex 24
ADMIN_SECRET=change-me-admin-secret

# ── PC-Worker secret ───────────────────────────────────────────────────────────
# Shared secret between the server and your home-PC worker.
# Must match worker_secret in C:\pc-worker\config.yaml on the home PC.
# Generate: openssl rand -hex 24
WORKER_SECRET=change-me-worker-secret

# ── Browserless token (protects the browserless Chrome service) ──────────────
# Generate: openssl rand -hex 24
BROWSERLESS_TOKEN=change-me-browserless-token

# ── UK Companies House API key ───────────────────────────────────────────────
# Free registration at: https://developer.company-information.service.gov.uk/
# Takes ~2 minutes, instant approval, no credit card.
COMPANIES_HOUSE_API_KEY=

# ── Optional: TED API key ─────────────────────────────────────────────────────
# Register free at https://api.ted.europa.eu/ for a TED API key.
# Leave empty to use the public (unauthenticated) endpoint.
TED_API_KEY=

# ── Optional: extra worker IPs (Hetzner secondary IPs or other VPS) ───────────
# Add additional worker IPs here for IP rotation.
# Format: http://IP:PORT  (comma-separated for multiple)
# Dynamic addition via: POST /admin/workers {"url":"http://IP:PORT"}
INSOLVENCY_WORKER_URLS=
ZVG_WORKER_URLS=
DPMA_WORKER_URLS=
BAFIN_WORKER_URLS=

# ── Resource limits ────────────────────────────────────────────────────────────
MAX_BROWSERS=2           # max concurrent Chrome instances per API (idle savings)
MAX_QUEUE_DEPTH=20       # queue depth before returning 429 (scraper APIs only)
BANDWIDTH_LIMIT_GB=15    # warn at 80%, block at 100% (Hetzner plan = 20TB)
LOG_LEVEL=info           # debug | info | warn | error

# ── Health Monitoring + Alerts ────────────────────────────────────────────────
# How often to check each API (seconds). Default 300 = every 5 minutes.
CHECK_INTERVAL_SEC=300

# Telegram bot (primary alerting — easiest, 2-minute setup):
#  1. Message @BotFather on Telegram → /newbot → copy the token
#  2. Start a chat with your new bot
#  3. curl https://api.telegram.org/bot<TOKEN>/getUpdates → copy "id" from result
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord webhook (optional — alternative or additional channel):
#  Discord server → channel ⚙ Settings → Integrations → Webhooks → New → copy URL
DISCORD_WEBHOOK_URL=

# Email alerts via SMTP (optional):
#  Gmail: host=smtp.gmail.com port=587, use App Password (not regular password)
#  Generate App Password: myaccount.google.com → Security → App Passwords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ── OpenSky Network (Aviation API) ───────────────────────────────────────────
# Optional: register free at https://opensky-network.org/index.php?option=com_users&view=registration
# Without credentials: 400 API credits/day (enough for demos)
# With credentials: 4000 credits/day
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── Contact Email (for OpenAlex + SEC EDGAR polite pools) ────────────────────
# Providing your email gives higher rate limits on these APIs.
CONTACT_EMAIL=help@novaroute.fyi

# ── ip-api.com (optional paid key for HTTPS + no rate limit) ────────────────
# Free tier: 45 req/min, HTTP only. Paid: https://members.ip-api.com/
IPAPI_KEY=

# ── CoinGecko (optional Demo API key) ────────────────────────────────────────
# Register free at: https://www.coingecko.com/en/api
# Demo key gives same rate limit (30/min) but more stable access.
COINGECKO_API_KEY=

# ── OpenFDA (optional API key for higher rate limits) ────────────────────────
# Register free at: https://open.fda.gov/apis/authentication/
# Without key: 240 req/min. With key: 1000 req/min.
OPENFDA_API_KEY=

# ── NASA Open APIs ───────────────────────────────────────────────────────────
# Register free at: https://api.nasa.gov/#signUp (instant, no credit card)
# Without key: DEMO_KEY (30 req/hour). With key: 1000 req/hour.
NASA_API_KEY=

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Password for the analytics dashboard at https://api.deine-domain.de/dashboard/
# Generate: openssl rand -base64 16
DASHBOARD_PASSWORD=change-me-dashboard-password

# ── API Gateway ───────────────────────────────────────────────────────────────
# Whether to allow requests without API keys (true = free anonymous access).
# Set false on RapidAPI/marketplace deployments where keys are always injected.
ALLOW_ANONYMOUS=true

# API keys in KEY:TIER format (comma-separated).
# Tiers: free (20/min), basic (100/min), pro (300/min), ultra (1000/min)
# Generate keys: openssl rand -hex 20
# Example: API_KEYS=abc123:pro,def456:basic,ghi789:free
# NOTE: do not add a second API_KEYS= line here — the one at the top of this file is the real one

# ── RapidAPI Marketplace ──────────────────────────────────────────────────────
# 1. Create account at https://rapidapi.com/provider
# 2. Create an API → copy the "Proxy Secret" from the API settings
# 3. Paste here — RapidAPI uses this to verify all requests come from their proxy
# Docs: https://docs.rapidapi.com/docs/api-provider-hub-quickstart
RAPIDAPI_PROXY_SECRET=

# ── Domain & SSL ──────────────────────────────────────────────────────────────
# Your server's domain name (used by setup-ssl.sh for Let's Encrypt)
DOMAIN=yourdomain.com
SSL_EMAIL=your@email.com

# ── GitHub Deployment ─────────────────────────────────────────────────────────
# Your GitHub repo URL (used by github-deploy.sh)
REPO_URL=https://github.com/YOUR_USER/YOUR_REPO.git
BRANCH=main
