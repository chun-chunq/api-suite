# Application
APP_ENV=development
PORT=8080

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Caching
CACHE_TTL=24h

# Rate limiting (requests per API key per minute)
RATE_LIMIT_PER_MINUTE=60

# Scraper
SCRAPE_TIMEOUT=45s
WORKER_CONCURRENCY=5
# Path to a system Chromium/Chrome binary. Leave empty to let go-rod download one.
BROWSER_BIN=

# Comma-separated list of valid customer API keys (replace before production).
API_KEYS=dev-key-123,test-key-456
