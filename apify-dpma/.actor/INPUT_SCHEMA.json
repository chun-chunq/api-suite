{
  "actorInputSchemaVersion": 1,
  "title": "DPMA Trademark Search",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "apiKey": { "title": "API Key", "type": "string", "editor": "textfield", "isSecret": true },
    "apiBaseUrl": { "title": "API Base URL", "type": "string", "editor": "textfield", "default": "https://api.yourdomain.com" },
    "name": { "title": "Trademark Name", "type": "string", "editor": "textfield", "description": "Trademark name or keyword to search" },
    "owner": { "title": "Owner", "type": "string", "editor": "textfield", "description": "Owner/applicant company or person name" },
    "class": { "title": "Nice Class", "type": "string", "editor": "textfield", "description": "Nice Classification class numbers, comma-separated (e.g. '9,35,42')" },
    "status": { "title": "Status Filter", "type": "string", "enum": ["registered","applied","expired","deleted"], "editor": "select" },
    "maxResults": { "title": "Max Results", "type": "integer", "default": 50, "minimum": 1, "maximum": 200, "editor": "number" }
  },
  "required": ["apiKey"]
}
